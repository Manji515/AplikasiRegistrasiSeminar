<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:fillViewport="true"
  android:background="@color/pastel_blue">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    >

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="40dp"
      android:layout_marginBottom="40dp"
      android:fontFamily="@font/inter_extrabold"
      android:gravity="center"
      android:text="PENDAFTARAN"
      android:textColor="@color/dark_green"
      android:textSize="24sp"
      android:textStyle="bold" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:background="@drawable/curve_bg"
      android:orientation="vertical"
      android:padding="24dp"
      android:elevation="4dp">

      <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="Nama">

        <com.google.android.material.textfield.TextInputEditText
          android:id="@+id/etNamaForm"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:alpha="140"
          android:fontFamily="@font/inter" />
      </com.google.android.material.textfield.TextInputLayout>

      <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Email">

        <com.google.android.material.textfield.TextInputEditText
          android:id="@+id/etEmailForm"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:alpha="140"
          android:fontFamily="@font/inter" />
      </com.google.android.material.textfield.TextInputLayout>

      <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Nomor HP">

        <com.google.android.material.textfield.TextInputEditText
          android:id="@+id/etPhoneForm"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:alpha="140"
          android:fontFamily="@font/inter" />
      </com.google.android.material.textfield.TextInputLayout>

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/inter_semibold"
        android:text="Jenis Kelamin"
        android:textColor="@color/dark_green"
        android:textStyle="bold" />

      <RadioGroup
        android:id="@+id/radioGroupGender"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <RadioButton
          android:id="@+id/rbLaki"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:fontFamily="@font/inter"
          android:text="Laki-laki" />

        <RadioButton
          android:id="@+id/rbPerempuan"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="20dp"
          android:fontFamily="@font/inter"
          android:text="Perempuan" />
      </RadioGroup>

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/inter_semibold"
        android:text="Pilihan Hobi"
        android:textColor="@color/dark_green"
        android:textStyle="bold" />

      <CheckBox
        android:id="@+id/cbHobi1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:text="Membaca" />

      <CheckBox
        android:id="@+id/cbHobi2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:text="Olahraga" />

      <CheckBox
        android:id="@+id/cbHobi3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:text="Musik" />

      <CheckBox
        android:id="@+id/cbHobi4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:text="Traveling" />

      <CheckBox
        android:id="@+id/cbHobi5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:text="Gaming" />

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/inter_semibold"
        android:text="Pilihan Seminar"
        android:textColor="@color/dark_green"
        android:textStyle="bold" />

      <Spinner
        android:id="@+id/spinnerSeminar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/inter"
        android:textColor="@color/dark_green"
        />

      <CheckBox
        android:id="@+id/cbAgreement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/inter"
        android:text="Saya menyetujui data yang diinput benar" />

      <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitRegistration"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/dark_green"
        android:fontFamily="@font/inter_semibold"
        android:text="Daftar"
        android:textAllCaps="false"
        android:textColor="@color/white"
        app:cornerRadius="16dp" />
    </LinearLayout>
  </LinearLayout>
</ScrollView>